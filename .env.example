# .env.example - copie para .env e preencha com seus caminhos
#
# IMPORTANTE: o arquivo .env (sem .example) NAO deve ser commitado.
# Ele esta no .gitignore.

# === OBRIGATORIO ===
# Pasta com volumes .h5 elegiveis (com bbox slice-level)
TCC_ANOTADOS_DIR=D:\Mri\anotados

# Caminho para o brain.csv do fastMRI+
TCC_BRAIN_CSV=D:\Mri\brain.csv

# === OPCIONAL (defaults sao relativos ao projeto) ===
# Descomente para sobrescrever:
# TCC_DATA_DIR=./data
# TCC_MASKS_DIR=./data/masks
# TCC_RECONS_DIR=./data/recons
# TCC_SPLITS_DIR=./splits
# TCC_CONFIGS_DIR=./configs
# TCC_FIGURES_DIR=./figures